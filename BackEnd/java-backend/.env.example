# ─────────────────────────────────────────────────────────────────────────────
# ThriftyBackpacker Java Backend — Environment Variables
# Copy this file to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── RapidAPI (required for all search endpoints) ──────────────────────────────
# Get your key from https://rapidapi.com — subscribe to the booking-com API.
RAPIDAPI_KEY=8562d7f7d4msh12d6344621e5222p13ae76jsn121638b672fe
# ── Database (optional — defaults to H2 in-memory for local dev) ──────────────
# Uncomment and fill in to use PostgreSQL instead of H2:
# DATABASE_URL=jdbc:postgresql://localhost:5432/thriftybackpacker
# DATABASE_USER=postgres
# DATABASE_PASSWORD=yourpassword
# DATABASE_DRIVER=org.postgresql.Driver
# HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ── Server port (optional, default: 8080) ────────────────────────────────────
# SERVER_PORT=8080

# ─────────────────────────────────────────────────────────────────────────────
# Frontend note:
# The Vue dev server proxies /api to http://localhost:8000 (Python backend).
# To use the Java backend instead, edit:
#   FrontEnd/travel-agency-platform/travel-agency-app/vite.config.js
# and change the proxy target from 8000 to 8080.
# ─────────────────────────────────────────────────────────────────────────────
