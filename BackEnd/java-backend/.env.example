# ─────────────────────────────────────────────────────────────────────────────
# ThriftyBackpacker Java Backend — Environment Variables
# Copy this file to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── RapidAPI (required for all search endpoints) ──────────────────────────────
RAPIDAPI_KEY=8562d7f7d4msh12d6344621e5222p13ae76jsn121638b672fe


# ── PostgreSQL ────────────────────────────────────────────────────────────────
# These match the docker-compose.yml defaults — no change needed for local dev.
DATABASE_URL=jdbc:postgresql://localhost:5432/thriftybackpacker
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# ─────────────────────────────────────────────────────────────────────────────
# Quick start:
#   1. docker compose up -d          (starts PostgreSQL)
#   2. export RAPIDAPI_KEY=...
#   3. ./mvnw spring-boot:run
#
# Frontend note:
#   Change vite.config.js proxy target from 8000 → 8080 to use this backend.
# ─────────────────────────────────────────────────────────────────────────────
